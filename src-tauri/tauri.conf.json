{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tTerm",
  "mainBinaryName": "tTerm",
  "version": "../package.json",
  "identifier": "com.stone.tTerm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tTerm",
        "label": "main",
        "center": true,
        "width": 800,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "appimage", "deb", "rpm"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMDgwRDY2RDRCMjU4REIKUldUYldMTFVaZzBJM3B0WXBtYmlXdmtqc1dnM0cwRzlaK1dhSEhoK0pzdms1bXNVcndUcDEzRjkK",
      "endpoints": [
        "https://330079598.github.io/tTerm/update/stable/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
